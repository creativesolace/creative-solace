---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
---
<style is:global>
.services-wrap { max-width: 760px; margin: 0 auto; padding: 48px 20px 80px; }
.service-block { padding: 36px 0; border-bottom: 1px solid rgba(60,20,40,.08); }
.service-block:last-child { border-bottom: none; }
.service-tag { display: inline-block; background: var(--pink-pale); border: 1px solid rgba(255,107,157,.25); border-radius: 50px; padding: 4px 14px; font-size: 11px; font-weight: 700; color: var(--pink); letter-spacing: .8px; text-transform: uppercase; margin-bottom: 14px; }
.service-block h2 { font-family: "Playfair Display", serif; font-size: clamp(22px, 5vw, 30px); font-weight: 700; color: var(--dark); margin-bottom: 14px; line-height: 1.2; }
.service-block p { font-size: 15px; line-height: 1.75; color: var(--mid); margin-bottom: 12px; font-weight: 300; }
.service-block p:last-child { margin-bottom: 0; }
.service-block strong { color: var(--text); font-weight: 600; }
.service-cta { display: inline-block; margin-top: 20px; background: var(--grad-pink); color: white; border: none; border-radius: 50px; padding: 12px 26px; font-family: "DM Sans", sans-serif; font-weight: 600; font-size: 14px; cursor: pointer; text-decoration: none; transition: transform .2s, box-shadow .2s; }
.service-cta:hover { transform: translateY(-2px); box-shadow: var(--shadow-soft); }
.service-cta.outline { background: none; color: var(--dark); border: 1.5px solid rgba(60,20,40,.2); margin-left: 10px; }
.service-cta.outline:hover { border-color: var(--pink); color: var(--pink); }
@media (min-width: 1024px) {
  .services-wrap { padding: 64px 40px 100px; }
  .service-block { padding: 48px 0; }
  .service-block h2 { font-size: 32px; }
  .service-block p { font-size: 16px; }
}
</style>

<BaseLayout
  lang="en"
  title="Our Services | Creative Solace | Rhinestone Kits, Workshops & Corporate Events"
  description="Everything Creative Solace offers: DIY rhinestone canvas kits, Paint and Sip workshops, Bedazzle and Sip events, private party packages, corporate team events, festival stands, and custom orders. Based in the Netherlands."
  canonical="https://creativesolace.com/services"
  ogTitle="Our Services | Creative Solace"
  ogDescription="DIY rhinestone kits, Paint and Sip, Bedazzle and Sip, private events, corporate workshops and more. Creative Solace, Netherlands."
  ogUrl="https://creativesolace.com/services"
  hreflangEn="https://creativesolace.com/services"
  hreflangNl="https://creativesolace.com/nl/services"
  activePage="services"
>
  <Fragment slot="head">
    <script type="application/ld+json">{JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ItemList",
      "name": "Creative Solace Services",
      "url": "https://creativesolace.com/services",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "item": { "@type": "Product", "name": "Rhinestone Canvas Kit", "description": "DIY rhinestone canvas kit including canvas, rhinestones, applicator pen, wax pad and B7000 adhesive. Ships within 1 to 3 business days.", "brand": { "@type": "Brand", "name": "Creative Solace" }, "offers": { "@type": "Offer", "priceCurrency": "EUR", "price": "44.99", "availability": "https://schema.org/InStock", "url": "https://creativesolace.com/#kits" } } },
        { "@type": "ListItem", "position": 2, "item": { "@type": "Service", "name": "Paint and Sip Workshop", "description": "Guided painting session with drinks for groups of 6 to 25. Available at your venue or ours across the Netherlands.", "provider": { "@type": "LocalBusiness", "name": "Creative Solace" }, "areaServed": { "@type": "Country", "name": "Netherlands" } } },
        { "@type": "ListItem", "position": 3, "item": { "@type": "Service", "name": "Bedazzle and Sip Workshop", "description": "Rhinestone canvas session with drinks for groups of 6 to 20. We come to your location anywhere in the Netherlands.", "provider": { "@type": "LocalBusiness", "name": "Creative Solace" }, "areaServed": { "@type": "Country", "name": "Netherlands" } } },
        { "@type": "ListItem", "position": 4, "item": { "@type": "Service", "name": "Corporate Creative Events", "description": "Team-building workshops, branded rhinestone kits, festival stands, and bespoke artwork commissions for businesses.", "provider": { "@type": "LocalBusiness", "name": "Creative Solace" }, "areaServed": { "@type": "Country", "name": "Netherlands" } } }
      ]
    })}</script>
  </Fragment>

  <div class="page-hero">
    <div class="page-hero-label">Creative Solace</div>
    <h1>Everything we <em>do</em></h1>
    <p class="page-hero-sub">From at-home DIY kits to workshops, corporate events, and festival stands. Here is a clear overview of everything Creative Solace offers.</p>
  </div>

  <div class="breadcrumb">
    <a href="/">Home</a> &rsaquo; Our Services
  </div>

  <div class="services-wrap">

    <div class="service-block reveal">
      <div class="service-tag">Shop online</div>
      <h2>Rhinestone Canvas Kits</h2>
      <p>Our kits let you create a stunning piece of art at home. No experience needed. Each kit comes with a printed canvas, all the rhinestones for that design, an applicator pen, a wax tray, and a tube of B7000 professional adhesive. You press each gem into place, section by section, and watch the image come to life.</p>
      <p>The canvas has a 4 cm gallery-wrap border, so it is ready to hang straight on the wall when you are done. No frame needed. <strong>Free shipping on all orders within the Netherlands.</strong> Ships within 1 to 3 business days.</p>
      <a href="/#kits" class="service-cta">Shop the kits ✨</a>
    </div>

    <div class="service-block reveal">
      <div class="service-tag">Workshop</div>
      <h2>Paint and Sip</h2>
      <p>A guided painting session with drinks. We bring all the materials. You bring the people. No painting experience needed at all. Everyone follows along at their own pace and goes home with a finished canvas.</p>
      <p><strong>Works great for:</strong> birthday parties, girls nights, hen dos, team outings, and open public events. Group size is 6 to 25 people. Sessions run 2 to 3 hours. We can come to your venue or host at ours.</p>
      <a href="/#workshops" class="service-cta">Request a quote</a>
    </div>

    <div class="service-block reveal">
      <div class="service-tag">Workshop</div>
      <h2>Bedazzle and Sip</h2>
      <p>Our most popular workshop. Guests each get their own rhinestone kit and work on it together during a drinks session. It is relaxed, fun, and satisfying. Everyone leaves with their own finished piece to take home.</p>
      <p><strong>Works great for:</strong> bachelorette parties, birthdays, corporate events, and girls nights. Group size is 6 to 20 people. Sessions run 2 to 3 hours. We come to you.</p>
      <a href="/#workshops" class="service-cta">Request a quote</a>
    </div>

    <div class="service-block reveal">
      <div class="service-tag">Private event</div>
      <h2>Bachelorette and Birthday Packages</h2>
      <p>We take care of everything so you can focus on the celebration. Materials, setup, guidance, and cleanup are all included. You choose the activity (paint, bedazzle, or both), we make it happen at your home, your venue, or a location of your choice.</p>
      <p>All guests take their finished artwork home as a keepsake. Custom themes are available on request. Planning is done over WhatsApp to keep things simple.</p>
      <a href="/#workshops" class="service-cta">Plan my event</a>
    </div>

    <div class="service-block reveal">
      <div class="service-tag">B2B</div>
      <h2>Corporate and Business Events</h2>
      <p>Creative workshops that genuinely bring teams together. We have hosted sessions for companies of all sizes and backgrounds. No creative experience is required and everyone takes part. It is hands-on, social, and a lot more memorable than the usual team outing.</p>
      <p>We also offer <strong>custom branded rhinestone kits</strong> for corporate gifting or merchandise, <strong>branded event stands</strong> at festivals and markets, and <strong>bespoke rhinestone artworks</strong> commissioned for your brand or office space.</p>
      <p>Send us an enquiry and we will put together a proposal within 24 hours.</p>
      <a href="/#b2b" class="service-cta">Get in touch</a>
    </div>

    <div class="service-block reveal">
      <div class="service-tag">Live events</div>
      <h2>Festival and Market Stands</h2>
      <p>We pop up at thrift markets, design fairs, and lifestyle festivals across the Netherlands. Our stand is interactive: visitors can try a kit in person, buy products, or find out about our workshops.</p>
      <p>If you organise an event and would like us there as a vendor or activity partner, get in touch and we will let you know our availability.</p>
      <a href="/#events" class="service-cta">See upcoming events</a>
      <a href="/#b2b" class="service-cta outline">Partner with us</a>
    </div>

    <div class="service-block reveal">
      <div class="service-tag">Custom</div>
      <h2>Custom Orders</h2>
      <p>Need something unique? We create custom rhinestone artwork, bespoke kit designs, and branded creative gifts on request. Prices depend on size and complexity.</p>
      <p>Send us a message with what you have in mind and we will come back to you within one business day.</p>
      <a href="mailto:hello@creativesolace.com" class="service-cta">Email us</a>
    </div>

  </div>

  <Fragment slot="scripts">
    <script is:inline>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => { if (entry.isIntersecting) { entry.target.classList.add('visible'); observer.unobserve(entry.target); } });
    }, { threshold: 0.08 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
    </script>
  </Fragment>

</BaseLayout>
