---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Privacy Policy | Creative Solace</title>
<meta name="description" content="Privacy policy for Creative Solace. How we collect, use, and protect your personal data in line with GDPR and Dutch law."/>
<meta name="robots" content="noindex"/>
<link rel="canonical" href="https://creativesolace.com/privacy"/>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&display=swap" rel="stylesheet"/>
<style>
:root {
  --pink:#FF6B9D;--pink-pale:#FFF0F5;--yellow:#FFD166;
  --cream:#FFF8F0;--dark:#1A0A14;--mid:#5C3049;--text:#3D1A2C;
  --grad-main:linear-gradient(135deg,#FFD166 0%,#FF9EC4 50%,#C084FC 100%);
  --grad-pink:linear-gradient(135deg,#FF6B9D,#FFBC42);
  --shadow-card:0 4px 24px rgba(60,20,40,.10);
  --radius:20px;--radius-sm:12px;--nav-h:60px;--tab-h:64px;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
body{font-family:'DM Sans',sans-serif;background:var(--cream);color:var(--text);overflow-x:hidden;padding-bottom:var(--tab-h);}
.announcement{background:var(--grad-main);color:var(--dark);text-align:center;padding:9px 16px;font-size:12px;font-weight:500;letter-spacing:.4px;position:relative;z-index:100;}
.announcement .sep{margin:0 6px;opacity:.35;}
.desktop-nav{display:none;}
.mobile-nav{position:sticky;top:0;z-index:200;background:rgba(255,248,240,.94);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);border-bottom:1px solid rgba(255,107,157,.12);height:var(--nav-h);display:flex;align-items:center;justify-content:space-between;padding:0 20px;}
.nav-logo{display:inline-flex;align-items:center;text-decoration:none;flex-shrink:0;}
.nav-logo img{height:40px;width:auto;display:block;object-fit:contain;}
.mobile-nav-actions{display:flex;align-items:center;gap:12px;}
.btn-cart-mobile{background:var(--grad-pink);color:white;border:none;border-radius:50px;padding:8px 16px;font-family:'DM Sans',sans-serif;font-weight:600;font-size:13px;cursor:pointer;text-decoration:none;display:inline-block;}
.page-hero{background:var(--dark);padding:52px 20px 48px;position:relative;overflow:hidden;text-align:center;}
.page-hero::before{content:'';position:absolute;top:-100px;left:50%;transform:translateX(-50%);width:500px;height:300px;background:var(--grad-main);opacity:.07;border-radius:50%;filter:blur(60px);}
.page-hero-label{font-size:10px;font-weight:700;letter-spacing:2.5px;text-transform:uppercase;color:var(--yellow);margin-bottom:12px;position:relative;z-index:1;}
.page-hero h1{font-family:'Playfair Display',serif;font-size:clamp(32px,8vw,56px);font-weight:900;color:white;line-height:1.1;margin-bottom:16px;position:relative;z-index:1;}
.page-hero h1 em{font-style:italic;background:var(--grad-pink);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.page-hero-sub{font-size:15px;line-height:1.65;color:rgba(255,255,255,.6);max-width:540px;margin:0 auto;position:relative;z-index:1;font-weight:300;}
.breadcrumb{padding:14px 20px;font-size:12px;color:var(--mid);border-bottom:1px solid rgba(60,20,40,.07);background:white;}
.breadcrumb a{color:var(--pink);text-decoration:none;}
.breadcrumb a:hover{text-decoration:underline;}
.content-wrap{max-width:760px;margin:0 auto;padding:48px 20px 80px;}
.last-updated{font-size:12px;color:var(--mid);margin-bottom:40px;padding:10px 16px;background:white;border-radius:var(--radius-sm);display:inline-block;}
.content-section{margin-bottom:44px;}
.content-section h2{font-family:'Playfair Display',serif;font-size:clamp(18px,4vw,24px);font-weight:700;color:var(--dark);margin-bottom:14px;padding-bottom:10px;border-bottom:2px solid var(--pink-pale);}
.content-section h3{font-size:14px;font-weight:600;color:var(--dark);margin:18px 0 6px;}
.content-section p{font-size:14px;line-height:1.75;color:var(--mid);margin-bottom:10px;font-weight:300;}
.content-section p:last-child{margin-bottom:0;}
.content-section a{color:var(--pink);}
.content-section ul{margin:8px 0 10px 0;padding-left:20px;}
.content-section ul li{font-size:14px;line-height:1.75;color:var(--mid);margin-bottom:4px;}
.content-section strong{color:var(--text);font-weight:600;}
.bottom-tab-bar{position:fixed;bottom:0;left:0;right:0;height:var(--tab-h);background:rgba(255,248,240,.96);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-top:1px solid rgba(255,107,157,.12);display:flex;align-items:stretch;z-index:300;padding-bottom:env(safe-area-inset-bottom);}
.tab-item{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3px;background:none;border:none;cursor:pointer;padding:6px 4px;text-decoration:none;color:var(--mid);-webkit-tap-highlight-color:transparent;}
.tab-icon{font-size:20px;line-height:1;}
.tab-label{font-size:9px;font-weight:600;letter-spacing:.5px;text-transform:uppercase;font-family:'DM Sans',sans-serif;}
footer{background:var(--dark);border-top:1px solid rgba(255,255,255,.06);padding:48px 20px 24px;}
.footer-brand{margin-bottom:36px;}
.footer-brand .nav-logo{display:block;margin-bottom:14px;}
.footer-tagline{font-size:13px;line-height:1.65;color:rgba(255,255,255,.45);margin-bottom:20px;}
.footer-social{display:flex;gap:10px;}
.social-btn{width:38px;height:38px;border-radius:50%;background:rgba(255,255,255,.07);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background .2s,transform .2s;color:white;text-decoration:none;}
.social-btn:hover{background:var(--pink);transform:translateY(-3px);}
.footer-cols{display:grid;grid-template-columns:1fr 1fr 1fr;gap:24px;margin-bottom:32px;}
.footer-col-title{font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,.35);margin-bottom:14px;}
.footer-links{list-style:none;display:flex;flex-direction:column;gap:10px;}
.footer-links a{text-decoration:none;font-size:13px;color:rgba(255,255,255,.55);transition:color .2s;}
.footer-links a:hover{color:var(--pink);}
.footer-bottom{border-top:1px solid rgba(255,255,255,.06);padding-top:20px;display:flex;flex-direction:column;gap:6px;font-size:11px;color:rgba(255,255,255,.3);}
@media(min-width:1024px){
  body{padding-bottom:0;}
  .mobile-nav{display:none;}
  .bottom-tab-bar{display:none;}
  .desktop-nav{display:flex;position:sticky;top:0;z-index:200;background:rgba(255,248,240,.92);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);border-bottom:1px solid rgba(255,107,157,.12);padding:0 60px;align-items:center;justify-content:space-between;height:70px;}
  .desktop-nav .nav-logo img{height:44px;}
  .nav-links{display:flex;gap:32px;list-style:none;align-items:center;}
  .nav-links a{text-decoration:none;color:var(--text);font-size:14px;font-weight:500;position:relative;transition:color .2s;}
  .nav-links a::after{content:'';position:absolute;bottom:-3px;left:0;right:0;height:2px;background:var(--grad-pink);border-radius:2px;transform:scaleX(0);transition:transform .25s;}
  .nav-links a:hover::after{transform:scaleX(1);}
  .nav-links a:hover{color:var(--pink);}
  .nav-actions{display:flex;align-items:center;gap:16px;}
  .btn-cart-desktop{background:var(--grad-pink);color:white;border:none;border-radius:50px;padding:9px 22px;font-family:'DM Sans',sans-serif;font-weight:600;font-size:14px;cursor:pointer;box-shadow:0 4px 16px rgba(255,107,157,.3);text-decoration:none;}
  .page-hero{padding:80px 40px 72px;}
  .page-hero-sub{font-size:17px;}
  .breadcrumb{padding:14px 80px;}
  .content-wrap{padding:64px 40px 100px;}
  .content-section p,.content-section ul li{font-size:15px;}
  footer{padding:60px 80px 30px;}
  .footer-brand{margin-bottom:0;}
  .footer-brand .nav-logo img{height:48px;}
  .footer-grid{display:grid;grid-template-columns:1.8fr 1fr 1fr 1fr;gap:48px;margin-bottom:48px;}
  .footer-cols{display:contents;}
  .footer-bottom{flex-direction:row;}
}
</style>
</head>
<body>

