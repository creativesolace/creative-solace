      {stars:'★★★★★',quote:'We booked the Bedazzle & Sip for my bachelorette and honestly it was the highlight of the whole weekend. Everyone left with their little masterpiece and huge smiles.',name:'Lisa van den Berg',handle:'@lisavdberg · Bedazzle & Sip workshop',emoji:'🌸'},
      {stars:'★★★★★',quote:'The kit arrived so beautifully packaged and the canvas quality is seriously impressive. I\'ve done 3 now and I just can\'t stop — it\'s so therapeutic and the results are stunning.',name:'Yasmine K.',handle:'@yasminecreates · Lucky 777 Kit',emoji:'💎'},
      {stars:'★★★★★',quote:'Booked Creative Solace for our company event — 30 people, mix of ages — and every single person was completely absorbed. Professional, fun, and unique. 10/10 would rebook!',name:'Emma Jansen',handle:'HR Manager · Corporate Team Event',emoji:'🏢'},
    ].map((t, i) => (
      <div class="testimonial-card reveal" style={`transition-delay:${i*0.1}s`}>
        <div class="testimonial-stars">{t.stars}</div>
        <div class="testimonial-quote">"</div>
        <p class="testimonial-text">{t.quote}</p>
        <div class="testimonial-author">
          <div class="author-avatar">{t.emoji}</div>
          <div><div class="author-name">{t.name}</div><div class="author-handle">{t.handle}</div></div>
        </div>
