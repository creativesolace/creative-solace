---
export const prerender = true;

import { getCollection } from 'astro:content';

// Load CMS content with fallbacks
let events = [], workshops = [], products = [], testimonials = [];
try { events = (await getCollection('events')).filter(e => e.data.featured).sort((a,b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime()).slice(0,3); } catch(e) {}
try { workshops = await getCollection('workshops'); } catch(e) {}
try { products = (await getCollection('products')).filter(p => p.data.available); } catch(e) {}
try { testimonials = (await getCollection('testimonials')).filter(t => t.data.featured); } catch(e) {}

const STRIPE_PK = import.meta.env.STRIPE_PUBLISHABLE_KEY || 'pk_live_51TVx4IC1ZOnsxU8kBY7mcTOIMKBzTMoK4OA1sjAl77HFEobLC1BMznlWoHele1Y8yN1fbM6i3da1yQr02yxbbF5u00pbTwj2VU';
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Creative Solace — Rhinestone Kits & Workshops</title>
<meta name="description" content="DIY rhinestone canvas kits, paint & sip nights, bedazzle workshops, and unforgettable events across the Netherlands."/>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&family=Dancing+Script:wght@700&display=swap" rel="stylesheet"/>
<script src="https://js.stripe.com/v3/" defer></script>
<style>
  :root {
    --pink:#FF6B9D;--pink-light:#FFB3CF;--pink-pale:#FFF0F5;
    --yellow:#FFD166;--yellow-warm:#FFBC42;--cream:#FFF8F0;
    --dark:#1A0A14;--mid:#5C3049;--text:#3D1A2C;
    --grad-main:linear-gradient(135deg,#FFD166 0%,#FF9EC4 50%,#C084FC 100%);
    --grad-pink:linear-gradient(135deg,#FF6B9D,#FFBC42);
    --grad-hero:linear-gradient(135deg,#FFF0A0 0%,#FFB3CF 40%,#D09FFF 80%,#A78BFA 100%);
    --shadow-soft:0 8px 40px rgba(255,107,157,0.18);
    --shadow-card:0 4px 24px rgba(60,20,40,0.10);
    --radius:20px;--radius-sm:12px;
  }
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
  html{scroll-behavior:smooth}
  body{font-family:'DM Sans',sans-serif;background:var(--cream);color:var(--text);overflow-x:hidden}

  .announcement{background:var(--grad-main);color:var(--dark);text-align:center;padding:10px 20px;font-size:13px;font-weight:500;letter-spacing:.5px;position:relative;z-index:100}
  .announcement span{margin:0 8px;opacity:.4}

  nav{position:sticky;top:0;z-index:200;background:rgba(255,248,240,0.92);backdrop-filter:blur(16px);border-bottom:1px solid rgba(255,107,157,0.12);padding:0 40px;display:flex;align-items:center;justify-content:space-between;height:70px}
  .nav-logo{font-family:'Dancing Script',cursive;font-size:28px;text-decoration:none;background:var(--grad-pink);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
  .nav-links{display:flex;gap:32px;list-style:none;align-items:center}
  .nav-links a{text-decoration:none;color:var(--text);font-size:14px;font-weight:500;position:relative;transition:color .2s}
  .nav-links a::after{content:'';position:absolute;bottom:-3px;left:0;right:0;height:2px;background:var(--grad-pink);border-radius:2px;transform:scaleX(0);transition:transform .25s}
  .nav-links a:hover::after{transform:scaleX(1)}
  .nav-links a:hover,.nav-links a.active{color:var(--pink)}
  .nav-links a.active::after{transform:scaleX(1)}
  .nav-actions{display:flex;align-items:center;gap:16px}
  .btn-cart{background:var(--grad-pink);color:white;border:none;border-radius:50px;padding:9px 22px;font-family:'DM Sans',sans-serif;font-weight:600;font-size:14px;cursor:pointer;transition:transform .2s,box-shadow .2s;box-shadow:0 4px 16px rgba(255,107,157,0.3)}
  .btn-cart:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(255,107,157,0.4)}

  .hero{min-height:90vh;display:grid;grid-template-columns:1fr 1fr;align-items:center;position:relative;overflow:hidden;padding:60px 80px;gap:40px}
  .hero::before{content:'';position:absolute;inset:0;background:var(--grad-hero);opacity:.35;z-index:0}
  .hero-blob{position:absolute;border-radius:50%;filter:blur(80px);z-index:0;pointer-events:none}
  .blob1{width:500px;height:500px;background:#FFD166;opacity:.4;top:-100px;right:-100px}
  .blob2{width:400px;height:400px;background:#FF6B9D;opacity:.3;bottom:-80px;left:40%}
  .blob3{width:300px;height:300px;background:#C084FC;opacity:.3;top:20%;left:-80px}
  .hero-content{position:relative;z-index:1;animation:fadeUp .8s ease both}
  .hero-badge{display:inline-block;background:rgba(255,255,255,0.7);border:1px solid rgba(255,107,157,0.3);border-radius:50px;padding:6px 16px;font-size:12px;font-weight:600;color:var(--pink);letter-spacing:1px;text-transform:uppercase;margin-bottom:20px;backdrop-filter:blur(8px)}
  .hero h1{font-family:'Playfair Display',serif;font-size:clamp(48px,6vw,82px);line-height:1.05;color:var(--dark);margin-bottom:20px}
  .hero h1 em{font-style:italic;background:var(--grad-pink);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
  .hero-sub{font-size:18px;line-height:1.6;color:var(--mid);max-width:460px;margin-bottom:36px;font-weight:300}
  .hero-ctas{display:flex;gap:14px;flex-wrap:wrap;align-items:center}
  .btn-primary{background:var(--dark);color:white;border:none;border-radius:50px;padding:15px 36px;font-family:'DM Sans',sans-serif;font-weight:600;font-size:15px;cursor:pointer;transition:transform .2s,box-shadow .2s,background .2s;text-decoration:none;display:inline-block}
  .btn-primary:hover{background:var(--pink);transform:translateY(-2px);box-shadow:var(--shadow-soft)}
  .btn-outline{background:rgba(255,255,255,0.7);color:var(--dark);border:1.5px solid rgba(60,20,40,0.2);border-radius:50px;padding:14px 32px;font-family:'DM Sans',sans-serif;font-weight:500;font-size:15px;cursor:pointer;transition:all .2s;text-decoration:none;display:inline-block;backdrop-filter:blur(8px)}
  .btn-outline:hover{border-color:var(--pink);color:var(--pink);transform:translateY(-2px)}
  .hero-trust{margin-top:40px;display:flex;align-items:center;gap:16px;font-size:13px;color:var(--mid)}
  .stars{color:var(--yellow-warm);font-size:16px;letter-spacing:1px}
  .hero-visual{position:relative;z-index:1;animation:fadeUp .8s .15s ease both}
  .hero-image-stack{position:relative;display:flex;justify-content:center}
  .hero-main-img{width:100%;max-width:520px;border-radius:30px;box-shadow:0 30px 80px rgba(60,20,40,0.2);object-fit:cover;aspect-ratio:4/5;display:block}
  .hero-float-card{position:absolute;background:rgba(255,255,255,0.92);backdrop-filter:blur(12px);border-radius:var(--radius-sm);padding:14px 18px;box-shadow:var(--shadow-card);border:1px solid rgba(255,255,255,0.8);animation:float 4s ease-in-out infinite}
  .hero-float-card.card-1{bottom:60px;left:-30px;display:flex;align-items:center;gap:12px}
  .hero-float-card.card-2{top:40px;right:-30px;text-align:center;animation-delay:-2s}
  .float-emoji{font-size:28px}.float-label{font-size:12px;font-weight:600;color:var(--text)}.float-sub{font-size:11px;color:var(--mid);margin-top:2px}
  .float-num{font-family:'Playfair Display',serif;font-size:26px;font-weight:900;color:var(--pink)}

  @keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}
  @keyframes fadeUp{from{opacity:0;transform:translateY(30px)}to{opacity:1;transform:translateY(0)}}
  @keyframes marquee{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}

  section{padding:90px 80px}
  .section-label{font-size:11px;font-weight:700;letter-spacing:2.5px;text-transform:uppercase;color:var(--pink);margin-bottom:12px}
  .section-title{font-family:'Playfair Display',serif;font-size:clamp(32px,4vw,52px);line-height:1.15;color:var(--dark);margin-bottom:16px}
  .section-title em{font-style:italic;background:var(--grad-pink);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
  .section-sub{font-size:17px;line-height:1.65;color:var(--mid);max-width:560px;font-weight:300}

  .marquee-section{background:var(--dark);padding:18px 0;overflow:hidden;white-space:nowrap}
  .marquee-track{display:inline-flex;animation:marquee 20s linear infinite}
  .marquee-item{display:inline-flex;align-items:center;gap:12px;padding:0 32px;font-size:13px;font-weight:500;color:rgba(255,255,255,0.6);letter-spacing:.5px}
  .marquee-dot{color:var(--pink);font-size:18px}

  .badges-section{background:white;padding:40px 80px;display:flex;align-items:center;justify-content:center;gap:60px;border-bottom:1px solid rgba(60,20,40,0.06)}
  .badge-item{display:flex;align-items:center;gap:12px;color:var(--mid);font-size:14px;font-weight:500}
  .badge-icon{font-size:26px}

  .how-it-works{background:white}
  .how-header{text-align:center;margin-bottom:64px}
  .how-header .section-sub{margin:0 auto}
  .steps-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:32px}
  .step-card{text-align:center;position:relative}
  .step-card::after{content:'→';position:absolute;right:-20px;top:30px;font-size:24px;color:var(--pink-light)}
  .step-card:last-child::after{display:none}
  .step-num{width:60px;height:60px;border-radius:50%;background:var(--grad-main);display:flex;align-items:center;justify-content:center;font-family:'Playfair Display',serif;font-size:24px;font-weight:900;color:white;margin:0 auto 20px;box-shadow:0 8px 24px rgba(255,107,157,0.3)}
  .step-icon{font-size:36px;margin-bottom:14px}
  .step-title{font-family:'Playfair Display',serif;font-size:18px;font-weight:700;color:var(--dark);margin-bottom:8px}
  .step-desc{font-size:14px;line-height:1.6;color:var(--mid)}

  .products-section{background:var(--cream)}
  .products-header{display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:48px;gap:20px}
  .products-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:24px}
  .product-card{background:white;border-radius:var(--radius);overflow:hidden;box-shadow:var(--shadow-card);transition:transform .3s,box-shadow .3s;cursor:pointer;position:relative}
  .product-card:hover{transform:translateY(-8px);box-shadow:0 16px 56px rgba(60,20,40,0.15)}
  .product-img-wrap{position:relative;overflow:hidden;aspect-ratio:1/1;background:var(--pink-pale)}
  .product-img-wrap img{width:100%;height:100%;object-fit:cover;transition:transform .5s;display:block}
  .product-card:hover .product-img-wrap img{transform:scale(1.06)}
  .product-badge{position:absolute;top:14px;left:14px;background:var(--pink);color:white;font-size:11px;font-weight:600;letter-spacing:.5px;padding:4px 10px;border-radius:50px}
  .product-quick-add{position:absolute;bottom:14px;left:14px;right:14px;background:rgba(255,255,255,0.95);border:none;border-radius:50px;padding:10px;font-family:'DM Sans',sans-serif;font-weight:600;font-size:13px;cursor:pointer;opacity:0;transform:translateY(8px);transition:opacity .25s,transform .25s;color:var(--dark)}
  .product-card:hover .product-quick-add{opacity:1;transform:translateY(0)}
  .product-info{padding:18px 18px 20px}
  .product-name{font-family:'Playfair Display',serif;font-size:17px;font-weight:700;color:var(--dark);margin-bottom:6px}
  .product-desc{font-size:12px;color:var(--mid);margin-bottom:12px;line-height:1.5}
  .product-price{display:flex;align-items:center;gap:10px}
  .price-now{font-weight:700;font-size:17px;color:var(--pink)}
  .price-old{font-size:13px;color:#aaa;text-decoration:line-through}

  .gallery-strip{padding:0 0 0 80px;overflow:hidden;background:white;padding-bottom:90px}
  .gallery-scroll{display:flex;gap:16px;overflow-x:auto;padding-bottom:8px;scrollbar-width:none;-ms-overflow-style:none;padding-right:80px}
  .gallery-scroll::-webkit-scrollbar{display:none}
  .gallery-item{flex-shrink:0;width:220px;height:280px;border-radius:var(--radius-sm);overflow:hidden;position:relative;cursor:pointer}
  .gallery-item img{width:100%;height:100%;object-fit:cover;transition:transform .5s}
  .gallery-item:hover img{transform:scale(1.08)}
  .gallery-item-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(26,10,20,0.6) 0%,transparent 60%);opacity:0;transition:opacity .3s;display:flex;align-items:flex-end;padding:16px}
  .gallery-item:hover .gallery-item-overlay{opacity:1}
  .gallery-tag{background:white;border-radius:50px;padding:5px 14px;font-size:12px;font-weight:600;color:var(--pink)}

  .workshops-section{background:var(--dark);color:white;position:relative;overflow:hidden}
  .workshops-section::before{content:'';position:absolute;top:-200px;right:-200px;width:600px;height:600px;background:radial-gradient(circle,rgba(255,107,157,0.15) 0%,transparent 70%);border-radius:50%}
  .workshops-section::after{content:'';position:absolute;bottom:-200px;left:-100px;width:500px;height:500px;background:radial-gradient(circle,rgba(255,209,102,0.1) 0%,transparent 70%);border-radius:50%}
  .workshops-header{position:relative;z-index:1}
  .workshops-header .section-title{color:white}
  .workshops-header .section-sub{color:rgba(255,255,255,0.6)}
  .workshops-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-top:56px;position:relative;z-index:1}
  .workshop-card{background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:var(--radius);padding:36px;transition:all .3s;position:relative;overflow:hidden;cursor:pointer}
  .workshop-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--grad-main);opacity:0;transition:opacity .3s}
  .workshop-card:hover{background:rgba(255,255,255,0.08);transform:translateY(-4px);border-color:rgba(255,107,157,0.3)}
  .workshop-card:hover::before{opacity:1}
  .workshop-emoji{font-size:48px;margin-bottom:20px}
  .workshop-label{font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--yellow);font-weight:600;margin-bottom:10px}
  .workshop-title{font-family:'Playfair Display',serif;font-size:26px;font-weight:700;color:white;margin-bottom:14px}
  .workshop-desc{font-size:15px;line-height:1.65;color:rgba(255,255,255,0.6);margin-bottom:28px}
  .workshop-meta{display:flex;gap:20px;margin-bottom:28px;flex-wrap:wrap}
  .meta-item{display:flex;align-items:center;gap:6px;font-size:13px;color:rgba(255,255,255,0.5)}
  .btn-workshop{background:var(--grad-pink);color:white;border:none;border-radius:50px;padding:13px 28px;font-family:'DM Sans',sans-serif;font-weight:600;font-size:14px;cursor:pointer;transition:all .2s;text-decoration:none;display:inline-block}
  .btn-workshop:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(255,107,157,0.4)}
  .workshop-large{grid-column:1/-1;display:grid;grid-template-columns:1fr 1fr;gap:36px;align-items:center}
  .workshop-large .workshop-img{border-radius:var(--radius-sm);overflow:hidden;aspect-ratio:16/9;background:rgba(255,255,255,0.05)}
  .workshop-large .workshop-img img{width:100%;height:100%;object-fit:cover;opacity:.8}

  .events-section{background:white}
  .events-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-top:52px}
  .event-card{border-radius:var(--radius);overflow:hidden;box-shadow:var(--shadow-card);transition:transform .3s,box-shadow .3s;cursor:pointer;background:var(--cream)}
  .event-card:hover{transform:translateY(-6px);box-shadow:0 20px 60px rgba(60,20,40,0.12)}
  .event-img{aspect-ratio:3/2;overflow:hidden;background:var(--pink-pale);position:relative}
  .event-img img{width:100%;height:100%;object-fit:cover;transition:transform .5s}
  .event-card:hover .event-img img{transform:scale(1.06)}
  .event-type-badge{position:absolute;top:14px;right:14px;background:white;border-radius:50px;padding:5px 14px;font-size:11px;font-weight:700;color:var(--pink);letter-spacing:.5px;text-transform:uppercase;box-shadow:var(--shadow-card)}
  .event-content{padding:24px}
  .event-date{font-size:12px;font-weight:600;color:var(--pink);letter-spacing:.5px;text-transform:uppercase;margin-bottom:8px}
  .event-title{font-family:'Playfair Display',serif;font-size:20px;font-weight:700;color:var(--dark);margin-bottom:8px}
  .event-location{font-size:13px;color:var(--mid);display:flex;align-items:center;gap:4px;margin-bottom:16px}
  .event-cta{font-size:13px;font-weight:600;color:var(--pink);text-decoration:none;display:flex;align-items:center;gap:4px;transition:gap .2s}
  .event-cta:hover{gap:8px}

  .b2b-section{background:linear-gradient(135deg,#FFF5E6 0%,#FFE8F0 100%);position:relative;overflow:hidden}
  .b2b-section::before{content:'✦';position:absolute;font-size:200px;color:rgba(255,107,157,0.06);right:60px;top:20px}
  .b2b-grid{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center}
  .b2b-perks{margin-top:36px;display:grid;grid-template-columns:1fr 1fr;gap:20px}
  .perk{background:white;border-radius:var(--radius-sm);padding:20px;box-shadow:var(--shadow-card)}
  .perk-icon{font-size:28px;margin-bottom:10px}
  .perk-title{font-weight:600;font-size:14px;color:var(--dark);margin-bottom:4px}
  .perk-desc{font-size:13px;color:var(--mid);line-height:1.5}
  .b2b-form{background:white;border-radius:var(--radius);padding:40px;box-shadow:var(--shadow-soft)}
  .form-title{font-family:'Playfair Display',serif;font-size:24px;font-weight:700;color:var(--dark);margin-bottom:6px}
  .form-sub{font-size:14px;color:var(--mid);margin-bottom:28px}
  .form-group{margin-bottom:18px}
  .form-row{display:grid;grid-template-columns:1fr 1fr;gap:16px}
  .form-label{display:block;font-size:12px;font-weight:600;letter-spacing:.5px;color:var(--text);margin-bottom:6px;text-transform:uppercase}
  .form-input,.form-select,.form-textarea{width:100%;border:1.5px solid rgba(60,20,40,0.12);border-radius:var(--radius-sm);padding:12px 16px;font-family:'DM Sans',sans-serif;font-size:14px;color:var(--text);background:var(--cream);transition:border-color .2s,box-shadow .2s;outline:none;appearance:none}
  .form-input:focus,.form-select:focus,.form-textarea:focus{border-color:var(--pink);box-shadow:0 0 0 3px rgba(255,107,157,0.12)}
  .form-textarea{resize:vertical;min-height:100px}
  .btn-submit{width:100%;background:var(--grad-pink);color:white;border:none;border-radius:50px;padding:15px;font-family:'DM Sans',sans-serif;font-weight:600;font-size:15px;cursor:pointer;transition:all .2s;margin-top:8px}
  .btn-submit:hover{transform:translateY(-2px);box-shadow:var(--shadow-soft)}

  .testimonials-section{background:var(--cream);text-align:center}
  .testimonials-header{margin-bottom:56px}
  .testimonials-header .section-sub{margin:0 auto}
  .testimonials-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;text-align:left}
  .testimonial-card{background:white;border-radius:var(--radius);padding:32px;box-shadow:var(--shadow-card);position:relative;transition:transform .3s}
  .testimonial-card:hover{transform:translateY(-4px)}
  .testimonial-quote{font-size:56px;line-height:.7;color:var(--pink-light);font-family:'Playfair Display',serif;font-weight:900;margin-bottom:16px}
  .testimonial-text{font-size:15px;line-height:1.7;color:var(--text);margin-bottom:24px;font-style:italic}
  .testimonial-author{display:flex;align-items:center;gap:12px}
  .author-avatar{width:44px;height:44px;border-radius:50%;background:var(--grad-main);display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}
  .author-name{font-weight:600;font-size:14px;color:var(--dark)}
  .author-handle{font-size:12px;color:var(--mid)}
  .testimonial-stars{color:var(--yellow-warm);font-size:14px;margin-bottom:12px}

  .newsletter-section{background:var(--dark);padding:80px;text-align:center;position:relative;overflow:hidden}
  .newsletter-section::before{content:'';position:absolute;width:600px;height:300px;background:var(--grad-main);opacity:.08;top:-100px;left:50%;transform:translateX(-50%);border-radius:50%;filter:blur(60px)}
  .newsletter-section .section-title{color:white;position:relative;z-index:1}
  .newsletter-section .section-sub{color:rgba(255,255,255,0.55);margin:0 auto 36px;position:relative;z-index:1}
  .newsletter-form{display:flex;gap:12px;max-width:440px;margin:0 auto;position:relative;z-index:1}
  .newsletter-input{flex:1;background:rgba(255,255,255,0.08);border:1.5px solid rgba(255,255,255,0.15);border-radius:50px;padding:14px 22px;font-family:'DM Sans',sans-serif;font-size:14px;color:white;outline:none;transition:border-color .2s}
  .newsletter-input::placeholder{color:rgba(255,255,255,0.35)}
  .newsletter-input:focus{border-color:rgba(255,107,157,0.6)}

  footer{background:var(--dark);border-top:1px solid rgba(255,255,255,0.06);padding:60px 80px 30px}
  .footer-grid{display:grid;grid-template-columns:1.8fr 1fr 1fr 1fr;gap:48px;margin-bottom:48px}
  .footer-brand .nav-logo{display:block;margin-bottom:16px;font-size:32px}
  .footer-tagline{font-size:14px;line-height:1.65;color:rgba(255,255,255,0.45);margin-bottom:24px}
  .footer-social{display:flex;gap:12px}
