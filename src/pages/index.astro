---
export const prerender = true;

import { getCollection } from 'astro:content';

// Load CMS content with fallbacks
let events = [], workshops = [], products = [], testimonials = [];
try { events = (await getCollection('events')).filter(e => e.data.featured).sort((a,b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime()).slice(0,3); } catch(e) {}
try { workshops = await getCollection('workshops'); } catch(e) {}
try { products = (await getCollection('products')).filter(p => p.data.available); } catch(e) {}
try { testimonials = (await getCollection('testimonials')).filter(t => t.data.featured); } catch(e) {}

const STRIPE_PK = import.meta.env.STRIPE_PUBLISHABLE_KEY || 'pk_live_51TVx4IC1ZOnsxU8kBY7mcTOIMKBzTMoK4OA1sjAl77HFEobLC1BMznlWoHele1Y8yN1fbM6i3da1yQr02yxbbF5u00pbTwj2VU';

function fmtDate(d) {
  if (!d) return '';
  try { return new Date(d).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' }); } catch { return String(d); }
}

function typeLabel(t) {
  const map = { festival: 'Festival', market: 'Thrift Market', workshop: 'Workshop Night', popup: 'Pop-up' };
  return map[t] || t;
}
