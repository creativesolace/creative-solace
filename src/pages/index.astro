<style>
/* ─────────────────────────────────────────
   TOKENS
───────────────────────────────────────── */
:root {
  --pink:        #FF6B9D;
  --pink-light:  #FFB3CF;
  --pink-pale:   #FFF0F5;
  --yellow:      #FFD166;
  --yellow-warm: #FFBC42;
  --cream:       #FFF8F0;
  --dark:        #1A0A14;
  --mid:         #5C3049;
  --text:        #3D1A2C;
  --white:       #FFFFFF;
  --grad-main:   linear-gradient(135deg,#FFD166 0%,#FF9EC4 50%,#C084FC 100%);
  --grad-pink:   linear-gradient(135deg,#FF6B9D,#FFBC42);
  --grad-hero:   linear-gradient(135deg,#FFF0A0 0%,#FFB3CF 40%,#D09FFF 80%,#A78BFA 100%);
  --shadow-soft: 0 8px 40px rgba(255,107,157,.18);
  --shadow-card: 0 4px 24px rgba(60,20,40,.10);
  --radius:      20px;
  --radius-sm:   12px;
  --nav-h:       60px;
  --tab-h:       64px;
}

/* ─────────────────────────────────────────
   RESET
───────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  font-family: 'DM Sans', sans-serif;
  background: var(--cream);
  color: var(--text);
  overflow-x: hidden;
  padding-bottom: var(--tab-h);
}

/* ─────────────────────────────────────────
   ANNOUNCEMENT BAR
───────────────────────────────────────── */
.announcement {
  background: var(--grad-main);
  color: var(--dark);
  text-align: center;
  padding: 9px 16px;
  font-size: 12px;
  font-weight: 500;
  letter-spacing: .4px;
  position: relative;
  z-index: 100;
  line-height: 1.4;
}
.announcement .sep { margin: 0 6px; opacity: .35; }

/* ─────────────────────────────────────────
   DESKTOP NAV (hidden on mobile)
───────────────────────────────────────── */
.desktop-nav {
  display: none;
}

/* ─────────────────────────────────────────
   MOBILE NAV (top bar)
───────────────────────────────────────── */
.mobile-nav {
  position: sticky;
  top: 0;
  z-index: 200;
  background: rgba(255,248,240,.94);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-bottom: 1px solid rgba(255,107,157,.12);
  height: var(--nav-h);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20px;
}

.nav-logo {
  display: inline-flex;
  align-items: center;
  text-decoration: none;
  flex-shrink: 0;
}

.nav-logo img {
  height: 40px;
  width: auto;
  display: block;
  object-fit: contain;
}

.mobile-nav-actions {
  display: flex;
  align-items: center;
  gap: 12px;
}

.nav-icon {
  background: none;
  border: none;
  cursor: pointer;
  font-size: 20px;
  color: var(--text);
  transition: color .2s;
  padding: 4px;
}
.nav-icon:hover { color: var(--pink); }

.btn-cart-mobile {
  background: var(--grad-pink);
  color: white;
  border: none;
  border-radius: 50px;
  padding: 8px 16px;
  font-family: 'DM Sans', sans-serif;
  font-weight: 600;
  font-size: 13px;
  cursor: pointer;
  transition: transform .2s, box-shadow .2s;
  box-shadow: 0 4px 16px rgba(255,107,157,.3);
  white-space: nowrap;
}
.btn-cart-mobile:hover { transform: translateY(-1px); box-shadow: 0 6px 20px rgba(255,107,157,.4); }

/* ─────────────────────────────────────────
   MOBILE BOTTOM TAB BAR
───────────────────────────────────────── */
.bottom-tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: var(--tab-h);
  background: rgba(255,248,240,.96);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-top: 1px solid rgba(255,107,157,.12);
  display: flex;
  align-items: stretch;
  z-index: 300;
  padding-bottom: env(safe-area-inset-bottom);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 3px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 6px 4px;
  text-decoration: none;
  transition: color .2s;
  color: var(--mid);
  -webkit-tap-highlight-color: transparent;
}

.tab-item.active { color: var(--pink); }

.tab-icon { font-size: 20px; line-height: 1; }
.tab-label { font-size: 9px; font-weight: 600; letter-spacing: .5px; text-transform: uppercase; font-family: 'DM Sans', sans-serif; }

/* ─────────────────────────────────────────
   HERO - MOBILE FIRST
───────────────────────────────────────── */
.hero {
  position: relative;
  overflow: hidden;
  padding: 36px 20px 48px;
  display: flex;
  flex-direction: column;
  gap: 32px;
}

.hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background: var(--grad-hero);
  opacity: .35;
  z-index: 0;
}

.hero-blob {
  position: absolute;
  border-radius: 50%;
  filter: blur(60px);
  z-index: 0;
  pointer-events: none;
}
.blob1 { width: 320px; height: 320px; background: #FFD166; opacity: .4; top: -80px; right: -80px; }
.blob2 { width: 260px; height: 260px; background: #FF6B9D; opacity: .3; bottom: -60px; left: 20%; }
.blob3 { width: 200px; height: 200px; background: #C084FC; opacity: .3; top: 30%; left: -60px; }

.hero-content {
  position: relative;
  z-index: 1;
  animation: fadeUp .8s ease both;
}

.hero-badge {
  display: inline-block;
  background: rgba(255,255,255,.75);
  border: 1px solid rgba(255,107,157,.3);
  border-radius: 50px;
  padding: 5px 14px;
  font-size: 11px;
  font-weight: 600;
  color: var(--pink);
  letter-spacing: .8px;
  text-transform: uppercase;
  margin-bottom: 16px;
  backdrop-filter: blur(8px);
}

.hero h1 {
  font-family: 'Playfair Display', serif;
  font-size: clamp(40px, 10vw, 72px);
  line-height: 1.05;
  color: var(--dark);
  margin-bottom: 16px;
}

.hero h1 em {
  font-style: italic;
  background: var(--grad-pink);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.hero-sub {
  font-size: 15px;
  line-height: 1.65;
  color: var(--mid);
  margin-bottom: 28px;
  font-weight: 300;
}

.hero-ctas {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.btn-primary {
  background: var(--dark);
  color: white;
  border: none;
  border-radius: 50px;
  padding: 15px 28px;
  font-family: 'DM Sans', sans-serif;
  font-weight: 600;
  font-size: 15px;
  cursor: pointer;
  transition: transform .2s, box-shadow .2s, background .2s;
  text-decoration: none;
  display: inline-block;
  text-align: center;
}
.btn-primary:hover { background: var(--pink); transform: translateY(-2px); box-shadow: var(--shadow-soft); }

.btn-outline {
  background: rgba(255,255,255,.7);
  color: var(--dark);
  border: 1.5px solid rgba(60,20,40,.2);
  border-radius: 50px;
  padding: 14px 28px;
  font-family: 'DM Sans', sans-serif;
  font-weight: 500;
  font-size: 15px;
  cursor: pointer;
  transition: all .2s;
  text-decoration: none;
  display: inline-block;
  text-align: center;
  backdrop-filter: blur(8px);
}
.btn-outline:hover { border-color: var(--pink); color: var(--pink); transform: translateY(-2px); }

.hero-trust {
  margin-top: 24px;
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 12px;
  color: var(--mid);
  flex-wrap: wrap;
}
.stars { color: var(--yellow-warm); font-size: 15px; letter-spacing: 1px; }

.hero-visual {
  position: relative;
  z-index: 1;
  animation: fadeUp .8s .15s ease both;
}

.hero-image-stack {
  position: relative;
}

.hero-main-img {
  width: 100%;
  border-radius: 24px;
  box-shadow: 0 20px 60px rgba(60,20,40,.2);
  object-fit: cover;
  aspect-ratio: 4/5;
  display: block;
}

.hero-float-card {
  position: absolute;
  background: rgba(255,255,255,.92);
  backdrop-filter: blur(12px);
  border-radius: var(--radius-sm);
  padding: 10px 14px;
  box-shadow: var(--shadow-card);
  border: 1px solid rgba(255,255,255,.8);
  animation: float 4s ease-in-out infinite;
}

.hero-float-card.card-1 {
  bottom: 20px;
  left: -12px;
  display: flex;
  align-items: center;
  gap: 10px;
}

.hero-float-card.card-2 {
  top: 20px;
  right: -12px;
  text-align: center;
  animation-delay: -2s;
}

.float-emoji { font-size: 22px; }
.float-label { font-size: 11px; font-weight: 600; color: var(--text); }
.float-sub { font-size: 10px; color: var(--mid); margin-top: 1px; }
.float-num { font-family: 'Playfair Display', serif; font-size: 22px; font-weight: 900; color: var(--pink); }

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50%       { transform: translateY(-8px); }
}
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(24px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ─────────────────────────────────────────
   PREVIOUSLY SEEN AT - ANIMATED
───────────────────────────────────────── */
.seen-at-section {
  background: var(--dark);
  padding: 0;
  border-bottom: 1px solid rgba(255,255,255,.06);
  overflow: hidden;
}

.seen-at-track-wrap {
  display: flex;
  align-items: center;
  height: 52px;
  overflow: hidden;
}

.seen-at-label-fixed {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: rgba(255,255,255,.35);
  white-space: nowrap;
  flex-shrink: 0;
  padding: 0 20px 0 20px;
  border-right: 1px solid rgba(255,255,255,.1);
  height: 100%;
  display: flex;
  align-items: center;
}

.seen-at-marquee {
  flex: 1;
  overflow: hidden;
  position: relative;
}

.seen-at-track {
  display: inline-flex;
  animation: seenAtScroll 22s linear infinite;
  white-space: nowrap;
}

.seen-at-track:hover { animation-play-state: paused; }

.seen-at-item {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 0 28px;
}

.seen-at-dot-anim { color: var(--pink); font-size: 8px; }

.seen-at-name {
  font-size: 13px;
  font-weight: 500;
  color: rgba(255,255,255,.55);
  text-decoration: none;
  transition: color .2s;
  white-space: nowrap;
}
.seen-at-name:hover { color: var(--pink); }

@keyframes seenAtScroll {
  0%   { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

/* ─────────────────────────────────────────
   BADGES ROW
───────────────────────────────────────── */
.badges-section {
  background: white;
  padding: 20px;
  display: flex;
  align-items: center;
  gap: 0;
  border-bottom: 1px solid rgba(60,20,40,.06);
  overflow-x: auto;
  scrollbar-width: none;
}
.badges-section::-webkit-scrollbar { display: none; }

.badge-item {
  display: flex;
  align-items: center;
  gap: 8px;
  color: var(--mid);
  font-size: 12px;
  font-weight: 500;
  white-space: nowrap;
  padding: 0 16px;
  border-right: 1px solid rgba(60,20,40,.08);
  flex-shrink: 0;
}
.badge-item:first-child { padding-left: 0; }
.badge-item:last-child { border-right: none; }
.badge-icon { font-size: 20px; }

/* ─────────────────────────────────────────
   SECTION COMMON
───────────────────────────────────────── */
section { padding: 56px 20px; }

.section-label {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: var(--pink);
  margin-bottom: 10px;
}

.section-title {
  font-family: 'Playfair Display', serif;
  font-size: clamp(28px, 7vw, 48px);
  line-height: 1.15;
  color: var(--dark);
  margin-bottom: 14px;
}

.section-title em {
  font-style: italic;
  background: var(--grad-pink);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.section-sub {
  font-size: 15px;
  line-height: 1.65;
  color: var(--mid);
  font-weight: 300;
}

/* ─────────────────────────────────────────
   HOW IT WORKS
───────────────────────────────────────── */
.how-it-works { background: white; }

.how-header { margin-bottom: 40px; text-align: center; }
.how-header .section-sub { margin: 0 auto; }

.steps-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
}

.step-card {
  text-align: center;
  padding: 20px 12px;
  background: var(--cream);
  border-radius: var(--radius-sm);
}

.step-icon { font-size: 28px; margin-bottom: 10px; }

.step-num {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: var(--grad-main);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Playfair Display', serif;
  font-size: 20px;
  font-weight: 900;
  color: white;
  margin: 0 auto 12px;
  box-shadow: 0 6px 20px rgba(255,107,157,.3);
}

.step-title {
  font-family: 'Playfair Display', serif;
  font-size: 15px;
  font-weight: 700;
  color: var(--dark);
  margin-bottom: 6px;
}

.step-desc {
  font-size: 12px;
  line-height: 1.6;
  color: var(--mid);
}

/* ─────────────────────────────────────────
   PRODUCTS
───────────────────────────────────────── */
.products-section { background: var(--cream); }

.products-header { margin-bottom: 28px; }
.products-header-row {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 12px;
  margin-top: 4px;
}

.products-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}

.product-card {
  background: white;
  border-radius: var(--radius);
  overflow: hidden;
  box-shadow: var(--shadow-card);
  transition: transform .3s, box-shadow .3s;
  cursor: pointer;
  position: relative;
}
.product-card:active { transform: scale(.98); }

.product-img-wrap {
  position: relative;
  overflow: hidden;
  aspect-ratio: 4/5;
  background: var(--pink-pale);
}

.product-img-wrap img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  transition: transform .5s;
  display: block;
  padding: 8px;
}

.product-card:hover .product-img-wrap img { transform: scale(1.06); }

.product-badge {
  position: absolute;
  top: 10px;
  left: 10px;
  background: var(--dark);
  color: white;
  font-size: 10px;
  font-weight: 600;
  letter-spacing: .4px;
  padding: 3px 8px;
  border-radius: 50px;
}
.product-badge.sale { background: var(--pink); }

.product-quick-add {
  position: absolute;
  bottom: 10px;
  left: 10px;
  right: 10px;
  background: rgba(255,255,255,.95);
  border: none;
  border-radius: 50px;
  padding: 8px;
  font-family: 'DM Sans', sans-serif;
  font-weight: 600;
  font-size: 11px;
  cursor: pointer;
  opacity: 0;
  transform: translateY(6px);
  transition: opacity .25s, transform .25s;
  color: var(--dark);
}
.product-card:hover .product-quick-add { opacity: 1; transform: translateY(0); }

.product-info { padding: 12px 12px 14px; }

.product-name {
  font-family: 'Playfair Display', serif;
  font-size: 14px;
  font-weight: 700;
  color: var(--dark);
  margin-bottom: 4px;
}

.product-desc {
  font-size: 11px;
  color: var(--mid);
  margin-bottom: 8px;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.product-meta-row {
  font-size: 10px;
  color: var(--mid);
  margin-bottom: 6px;
  letter-spacing: .2px;
}

.product-price { display: flex; align-items: center; gap: 6px; }
.price-now { font-weight: 700; font-size: 15px; color: var(--pink); }
.price-old { font-size: 11px; color: #aaa; text-decoration: line-through; }

/* ─────────────────────────────────────────
   GALLERY STRIP
───────────────────────────────────────── */
.gallery-section { background: white; padding: 56px 0 56px; }
.gallery-header { padding: 0 20px 24px; }

.gallery-scroll {
  display: flex;
  gap: 12px;
  overflow-x: auto;
  padding: 0 20px;
  scrollbar-width: none;
  -ms-overflow-style: none;
}
.gallery-scroll::-webkit-scrollbar { display: none; }

.gallery-item {
  flex-shrink: 0;
  width: 160px;
  height: 200px;
  border-radius: var(--radius-sm);
  overflow: hidden;
  position: relative;
  cursor: pointer;
}

.gallery-item img { width: 100%; height: 100%; object-fit: cover; transition: transform .5s; }
.gallery-item:hover img { transform: scale(1.08); }

.gallery-item-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(26,10,20,.6) 0%, transparent 60%);
  opacity: 0;
  transition: opacity .3s;
  display: flex;
  align-items: flex-end;
  padding: 12px;
}
.gallery-item:hover .gallery-item-overlay { opacity: 1; }

.gallery-tag {
  background: white;
  border-radius: 50px;
  padding: 4px 10px;
  font-size: 10px;
  font-weight: 600;
  color: var(--pink);
}

/* ─────────────────────────────────────────
   WORKSHOPS
───────────────────────────────────────── */
.workshops-section {
  background: var(--dark);
  color: white;
  position: relative;
  overflow: hidden;
}

.workshops-section::before {
  content: '';
  position: absolute;
  top: -150px; right: -150px;
  width: 400px; height: 400px;
  background: radial-gradient(circle,rgba(255,107,157,.15) 0%,transparent 70%);
  border-radius: 50%;
}

.workshops-header .section-title { color: white; }
.workshops-header .section-sub { color: rgba(255,255,255,.6); }
.workshops-header { margin-bottom: 32px; position: relative; z-index: 1; }

.workshops-grid {
  display: flex;
  flex-direction: column;
  gap: 16px;
  position: relative;
  z-index: 1;
}

.workshop-card {
  background: rgba(255,255,255,.05);
  border: 1px solid rgba(255,255,255,.1);
  border-radius: var(--radius);
  padding: 28px 24px;
  transition: all .3s;
  position: relative;
  overflow: hidden;
  cursor: pointer;
}

.workshop-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: var(--grad-main);
  opacity: 0;
  transition: opacity .3s;
}

.workshop-card:hover { background: rgba(255,255,255,.08); border-color: rgba(255,107,157,.3); }
.workshop-card:hover::before { opacity: 1; }

.workshop-emoji { font-size: 36px; margin-bottom: 14px; }

.workshop-label {
  font-size: 10px;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--yellow);
  font-weight: 600;
  margin-bottom: 8px;
}

.workshop-title {
  font-family: 'Playfair Display', serif;
  font-size: 22px;
  font-weight: 700;
  color: white;
  margin-bottom: 12px;
}

.workshop-desc {
  font-size: 14px;
  line-height: 1.65;
  color: rgba(255,255,255,.6);
  margin-bottom: 20px;
}

.workshop-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  margin-bottom: 24px;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 5px;
  font-size: 12px;
  color: rgba(255,255,255,.5);
}
.meta-item span:first-child { font-size: 14px; }

.btn-workshop {
  background: var(--grad-pink);
  color: white;
  border: none;
  border-radius: 50px;
  padding: 12px 24px;
  font-family: 'DM Sans', sans-serif;
  font-weight: 600;
  font-size: 14px;
  cursor: pointer;
  transition: all .2s;
  text-decoration: none;
  display: inline-block;
}
.btn-workshop:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(255,107,157,.4); }

.workshop-large { display: flex; flex-direction: column; gap: 24px; }
.workshop-large .workshop-img {
  border-radius: var(--radius-sm);
  overflow: hidden;
  aspect-ratio: 16/9;
  background: rgba(255,255,255,.05);
}
.workshop-large .workshop-img img { width: 100%; height: 100%; object-fit: cover; opacity: .8; }

/* ─────────────────────────────────────────
   EVENTS
───────────────────────────────────────── */
.events-section { background: white; }

.events-grid {
  display: flex;
  flex-direction: column;
  gap: 16px;
  margin-top: 32px;
}

.event-card {
  border-radius: var(--radius);
  overflow: hidden;
  box-shadow: var(--shadow-card);
  transition: transform .3s, box-shadow .3s;
  cursor: pointer;
  background: var(--cream);
}
.event-card:active { transform: scale(.98); }

.event-img {
  aspect-ratio: 3/2;
  overflow: hidden;
  background: var(--pink-pale);
  position: relative;
}

.event-img-slider {
  display: flex;
  height: 100%;
  transition: transform .4s ease;
  will-change: transform;
}

.event-img-slide {
  flex-shrink: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.event-img img { width: 100%; height: 100%; object-fit: cover; transition: transform .5s; display: block; }
.event-card:hover .event-img img { transform: scale(1.06); }

.event-img-dots {
  position: absolute;
  bottom: 10px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 5px;
  z-index: 2;
}

.event-img-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: rgba(255,255,255,.5);
  border: none;
  cursor: pointer;
  padding: 0;
  transition: background .2s;
}
.event-img-dot.active { background: white; }

.event-img-nav {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  background: rgba(255,255,255,.88);
  border: none;
  border-radius: 50%;
  width: 28px; height: 28px;
  font-size: 12px;
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  opacity: 0;
  transition: opacity .2s;
  z-index: 2;
}
.event-img-nav.prev { left: 8px; }
.event-img-nav.next { right: 8px; }
.event-card:hover .event-img-nav { opacity: 1; }

.event-type-badge {
  position: absolute;
  top: 12px;
  right: 12px;
  background: white;
  border-radius: 50px;
  padding: 4px 12px;
  font-size: 10px;
  font-weight: 700;
  color: var(--pink);
  letter-spacing: .4px;
  text-transform: uppercase;
  box-shadow: var(--shadow-card);
}

.event-content { padding: 20px; }

.event-date {
  font-size: 11px;
  font-weight: 600;
  color: var(--pink);
  letter-spacing: .4px;
  text-transform: uppercase;
  margin-bottom: 6px;
}

.event-title {
  font-family: 'Playfair Display', serif;
  font-size: 18px;
  font-weight: 700;
  color: var(--dark);
  margin-bottom: 6px;
}

.event-location {
  font-size: 12px;
  color: var(--mid);
  margin-bottom: 10px;
}

.event-desc {
  font-size: 12px;
  color: var(--mid);
  line-height: 1.5;
}

.coming-soon-events {
  margin-top: 24px;
  background: var(--pink-pale);
  border: 1.5px dashed rgba(255,107,157,.3);
  border-radius: var(--radius);
  padding: 24px 20px;
}

.coming-soon-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 12px;
}

.coming-soon-icon { font-size: 28px; }

.coming-soon-title {
  font-family: 'Playfair Display', serif;
  font-size: 17px;
  font-weight: 700;
  color: var(--dark);
}

.coming-soon-sub { font-size: 13px; color: var(--mid); }

/* ─────────────────────────────────────────
   B2B
───────────────────────────────────────── */
.b2b-section {
  background: linear-gradient(135deg,#FFF5E6 0%,#FFE8F0 100%);
  position: relative;
  overflow: hidden;
}

.b2b-grid { display: flex; flex-direction: column; gap: 40px; }

.b2b-perks {
  margin-top: 24px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}

.perk {
  background: white;
  border-radius: var(--radius-sm);
  padding: 16px;
  box-shadow: var(--shadow-card);
}

.perk-icon { font-size: 24px; margin-bottom: 8px; }
.perk-title { font-weight: 600; font-size: 13px; color: var(--dark); margin-bottom: 4px; }
.perk-desc { font-size: 11px; color: var(--mid); line-height: 1.5; }

.b2b-form {
  background: white;
  border-radius: var(--radius);
  padding: 28px 20px;
  box-shadow: var(--shadow-soft);
}

.form-title {
  font-family: 'Playfair Display', serif;
  font-size: 22px;
  font-weight: 700;
  color: var(--dark);
  margin-bottom: 4px;
}

.form-sub { font-size: 13px; color: var(--mid); margin-bottom: 24px; }

.form-group { margin-bottom: 16px; }

.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }

.form-label {
  display: block;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: .5px;
  color: var(--text);
  margin-bottom: 5px;
  text-transform: uppercase;
}

.form-input, .form-select, .form-textarea {
  width: 100%;
  border: 1.5px solid rgba(60,20,40,.12);
  border-radius: var(--radius-sm);
  padding: 12px 14px;
  font-family: 'DM Sans', sans-serif;
  font-size: 14px;
  color: var(--text);
  background: var(--cream);
  transition: border-color .2s, box-shadow .2s;
  outline: none;
  appearance: none;
  -webkit-appearance: none;
}

.form-input:focus, .form-select:focus, .form-textarea:focus {
  border-color: var(--pink);
  box-shadow: 0 0 0 3px rgba(255,107,157,.12);
}

.form-textarea { resize: vertical; min-height: 90px; }

.btn-submit {
  width: 100%;
  background: var(--grad-pink);
  color: white;
  border: none;
  border-radius: 50px;
  padding: 15px;
  font-family: 'DM Sans', sans-serif;
  font-weight: 600;
  font-size: 15px;
  cursor: pointer;
  transition: all .2s;
  margin-top: 8px;
}
.btn-submit:hover { transform: translateY(-2px); box-shadow: var(--shadow-soft); }

/* ─────────────────────────────────────────
   REVIEWS
───────────────────────────────────────── */
.testimonials-section { background: var(--cream); text-align: center; }
.testimonials-header { margin-bottom: 40px; }

.reviews-empty { padding: 40px 20px; }
.reviews-empty-icon { font-size: 48px; margin-bottom: 16px; }
.reviews-empty-title {
  font-family: 'Playfair Display', serif;
  font-size: 22px;
  font-weight: 700;
  color: var(--dark);
  margin-bottom: 10px;
}
.reviews-empty-sub { font-size: 14px; color: var(--mid); line-height: 1.65; }

.star-rating { display: flex; gap: 6px; justify-content: flex-start; }
.star-btn {
  background: none;
  border: none;
  font-size: 32px;
  color: #ddd;
  cursor: pointer;
  transition: color .15s, transform .15s;
  padding: 0;
  line-height: 1;
}
.star-btn.active { color: var(--yellow-warm); }
.star-btn:hover { transform: scale(1.15); }

.testimonials-grid {
  display: flex;
  flex-direction: column;
  gap: 16px;
  text-align: left;
}

.testimonial-card {
  background: white;
  border-radius: var(--radius);
  padding: 24px;
  box-shadow: var(--shadow-card);
}

.testimonial-quote {
  font-size: 48px;
  line-height: 0.7;
  color: var(--pink-light);
  font-family: 'Playfair Display', serif;
  font-weight: 900;
  margin-bottom: 12px;
}

.testimonial-text {
  font-size: 14px;
  line-height: 1.7;
  color: var(--text);
  margin-bottom: 20px;
  font-style: italic;
}

.testimonial-author { display: flex; align-items: center; gap: 10px; }
.author-avatar {
  width: 40px; height: 40px;
  border-radius: 50%;
  background: var(--grad-main);
  display: flex; align-items: center; justify-content: center;
  font-size: 16px; flex-shrink: 0;
}
.author-name { font-weight: 600; font-size: 13px; color: var(--dark); }
.author-handle { font-size: 11px; color: var(--mid); }
.testimonial-stars { color: var(--yellow-warm); font-size: 13px; margin-bottom: 10px; }

/* ─────────────────────────────────────────
   NEWSLETTER
───────────────────────────────────────── */
.newsletter-section {
  background: var(--dark);
  padding: 56px 20px;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.newsletter-section::before {
  content: '';
  position: absolute;
  width: 400px; height: 200px;
  background: var(--grad-main);
  opacity: .07;
  top: -60px; left: 50%;
  transform: translateX(-50%);
  border-radius: 50%;
  filter: blur(40px);
}
.newsletter-section .section-title { color: white; position: relative; z-index: 1; }
.newsletter-section .section-sub { color: rgba(255,255,255,.55); margin: 0 auto 28px; position: relative; z-index: 1; }

.newsletter-form {
  display: flex;
  flex-direction: column;
  gap: 10px;
  position: relative;
  z-index: 1;
}

.newsletter-input {
  width: 100%;
  background: rgba(255,255,255,.08);
  border: 1.5px solid rgba(255,255,255,.15);
  border-radius: 50px;
  padding: 14px 20px;
  font-family: 'DM Sans', sans-serif;
  font-size: 14px;
  color: white;
  outline: none;
  transition: border-color .2s;
}
.newsletter-input::placeholder { color: rgba(255,255,255,.35); }
.newsletter-input:focus { border-color: rgba(255,107,157,.6); }

/* ─────────────────────────────────────────
   FOOTER
───────────────────────────────────────── */
footer {
  background: var(--dark);
  border-top: 1px solid rgba(255,255,255,.06);
  padding: 48px 20px 24px;
}

.footer-brand { margin-bottom: 36px; }
.footer-brand .nav-logo { display: block; margin-bottom: 14px; }

.footer-tagline {
  font-size: 13px;
  line-height: 1.65;
  color: rgba(255,255,255,.45);
  margin-bottom: 20px;
}

.footer-social { display: flex; gap: 10px; }

.social-btn {
  width: 38px; height: 38px;
  border-radius: 50%;
  background: rgba(255,255,255,.07);
  border: none;
  cursor: pointer;
  font-size: 16px;
  display: flex; align-items: center; justify-content: center;
  transition: background .2s, transform .2s;
  color: white;
  text-decoration: none;
}
.social-btn:hover { background: var(--pink); transform: translateY(-3px); }

.footer-cols {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 24px;
  margin-bottom: 32px;
}

.footer-col-title {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: rgba(255,255,255,.35);
  margin-bottom: 14px;
}

.footer-links { list-style: none; display: flex; flex-direction: column; gap: 10px; }
.footer-links a {
  text-decoration: none;
  font-size: 13px;
  color: rgba(255,255,255,.55);
  transition: color .2s;
}
.footer-links a:hover { color: var(--pink); }

.footer-bottom {
  border-top: 1px solid rgba(255,255,255,.06);
  padding-top: 20px;
  display: flex;
  flex-direction: column;
  gap: 6px;
  font-size: 11px;
  color: rgba(255,255,255,.3);
}

/* ─────────────────────────────────────────
   CART DRAWER
───────────────────────────────────────── */
.cart-drawer {
  position: fixed;
  top: 0;
  right: -100%;
  width: 100%;
  max-width: 380px;
  height: 100vh;
  background: white;
  z-index: 500;
  box-shadow: -20px 0 60px rgba(60,20,40,.15);
  transition: right .35s cubic-bezier(.4,0,.2,1);
  display: flex;
  flex-direction: column;
}
.cart-drawer.open { right: 0; }

.cart-header {
  padding: 20px;
  border-bottom: 1px solid rgba(60,20,40,.08);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.cart-title { font-family: 'Playfair Display', serif; font-size: 18px; font-weight: 700; color: var(--dark); }
.cart-items { flex: 1; overflow-y: auto; padding: 20px; }

.cart-empty { text-align: center; padding: 48px 16px; color: var(--mid); }
.cart-empty-emoji { font-size: 48px; margin-bottom: 14px; }
.cart-empty p { font-size: 14px; }

.cart-footer { padding: 20px; border-top: 1px solid rgba(60,20,40,.08); }
.cart-total { display: flex; justify-content: space-between; font-weight: 600; font-size: 15px; color: var(--dark); margin-bottom: 14px; }

.cart-overlay-bg {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(26,10,20,.4);
  z-index: 499;
  backdrop-filter: blur(4px);
}
.cart-overlay-bg.active { display: block; }

/* ─────────────────────────────────────────
   MODALS
───────────────────────────────────────── */
.modal-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(26,10,20,.7);
  z-index: 600;
  backdrop-filter: blur(8px);
  align-items: flex-end;
  justify-content: center;
  padding: 0;
}
.modal-overlay.active { display: flex; }

.modal {
  background: white;
  border-radius: var(--radius) var(--radius) 0 0;
  padding: 32px 20px;
  width: 100%;
  position: relative;
  animation: slideUp .3s ease;
  max-height: 90vh;
  overflow-y: auto;
}

@keyframes slideUp {
  from { transform: translateY(60px); opacity: 0; }
  to   { transform: translateY(0); opacity: 1; }
}

.modal-close {
  position: absolute;
  top: 16px;
  right: 16px;
  background: none;
  border: none;
  font-size: 20px;
  cursor: pointer;
  color: var(--mid);
  transition: color .2s;
  width: 32px; height: 32px;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
}
.modal-close:hover { color: var(--pink); background: var(--pink-pale); }

.modal-pill {
  width: 40px; height: 4px;
  background: rgba(60,20,40,.15);
  border-radius: 2px;
  margin: 0 auto 20px;
}

.modal-title {
  font-family: 'Playfair Display', serif;
  font-size: 24px;
  font-weight: 700;
  color: var(--dark);
  margin-bottom: 6px;
}
.modal-sub { font-size: 13px; color: var(--mid); margin-bottom: 24px; }

/* ─────────────────────────────────────────
   SCROLL REVEAL
───────────────────────────────────────── */
.reveal {
  opacity: 0;
  transform: translateY(20px);
  transition: opacity .55s ease, transform .55s ease;
}
.reveal.visible { opacity: 1; transform: translateY(0); }

/* ─────────────────────────────────────────
   UTILITIES
───────────────────────────────────────── */
.text-center { text-align: center; }
.mt-4 { margin-top: 16px; }
.mt-6 { margin-top: 24px; }

/* ═════════════════════════════════════════
   DESKTOP OVERRIDES (min-width: 1024px)
═════════════════════════════════════════ */
@media (min-width: 1024px) {
  body { padding-bottom: 0; }

  .mobile-nav  { display: none; }
  .bottom-tab-bar { display: none; }

  .desktop-nav {
    display: flex;
    position: sticky;
    top: 0;
    z-index: 200;
    background: rgba(255,248,240,.92);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(255,107,157,.12);
    padding: 0 60px;
    align-items: center;
    justify-content: space-between;
    height: 70px;
  }

  .desktop-nav .nav-logo img { height: 44px; }

  .nav-links {
    display: flex;
    gap: 32px;
    list-style: none;
    align-items: center;
  }

  .nav-links a {
    text-decoration: none;
    color: var(--text);
    font-size: 14px;
    font-weight: 500;
    position: relative;
    transition: color .2s;
  }

  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: -3px; left: 0; right: 0;
    height: 2px;
    background: var(--grad-pink);
    border-radius: 2px;
    transform: scaleX(0);
    transition: transform .25s;
  }

  .nav-links a:hover::after, .nav-links a.active::after { transform: scaleX(1); }
  .nav-links a:hover, .nav-links a.active { color: var(--pink); }

  .nav-actions { display: flex; align-items: center; gap: 16px; }

  .btn-cart-desktop {
    background: var(--grad-pink);
    color: white;
    border: none;
    border-radius: 50px;
    padding: 9px 22px;
    font-family: 'DM Sans', sans-serif;
    font-weight: 600;
    font-size: 14px;
    cursor: pointer;
    transition: transform .2s, box-shadow .2s;
    box-shadow: 0 4px 16px rgba(255,107,157,.3);
  }
  .btn-cart-desktop:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(255,107,157,.4); }

  .announcement { font-size: 13px; padding: 10px 20px; }

  .seen-at-label-fixed { padding: 0 32px 0 40px; font-size: 11px; }
  .seen-at-item { padding: 0 36px; }
  .seen-at-name { font-size: 14px; }

  .badges-section {
    padding: 32px 60px;
    justify-content: center;
    gap: 0;
    overflow-x: visible;
  }
  .badge-item { font-size: 14px; padding: 0 40px; }
  .badge-icon { font-size: 24px; }

  section { padding: 90px 80px; }

  .hero {
    min-height: 90vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    padding: 60px 80px;
    gap: 40px;
    flex-direction: unset;
  }

  .blob1 { width: 500px; height: 500px; top: -100px; right: -100px; }
  .blob2 { width: 400px; height: 400px; bottom: -80px; left: 40%; }
  .blob3 { width: 300px; height: 300px; top: 20%; left: -80px; }

  .hero-sub { font-size: 18px; max-width: 460px; }
  .hero-ctas { flex-direction: row; }

  .hero-main-img { max-width: 520px; border-radius: 30px; aspect-ratio: 4/5; }

  .hero-float-card.card-1 { bottom: 60px; left: -30px; }
  .hero-float-card.card-2 { top: 40px; right: -30px; }
  .float-emoji { font-size: 28px; }
  .float-label { font-size: 12px; }
  .float-sub { font-size: 11px; }
  .float-num { font-size: 26px; }

  .steps-grid {
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
  }

  .step-card {
    background: transparent;
    padding: 0;
    position: relative;
  }

  .step-card::after {
    content: '→';
    position: absolute;
    right: -20px;
    top: 22px;
    font-size: 24px;
    color: var(--pink-light);
  }
  .step-card:last-child::after { display: none; }

  .step-num { width: 60px; height: 60px; font-size: 24px; }
  .step-icon { font-size: 36px; }
  .step-title { font-size: 18px; }
  .step-desc { font-size: 14px; }

  .products-grid { grid-template-columns: repeat(4, 1fr); gap: 24px; }
  .product-name { font-size: 17px; }
  .product-desc { font-size: 12px; -webkit-line-clamp: unset; }
  .product-info { padding: 18px 18px 20px; }

  .gallery-section { padding: 0 0 90px; }
  .gallery-header { padding: 90px 80px 32px; }
  .gallery-scroll { padding: 0 80px; }
  .gallery-item { width: 220px; height: 280px; }

  .workshops-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
  .workshop-large {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 36px;
    align-items: center;
    flex-direction: unset;
  }

  .events-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 52px;
  }

  .coming-soon-inner { flex-direction: row; text-align: left; }
