// ── REVIEW MODAL ──
let selectedRating = 0;

function openReviewModal() {
  document.getElementById('reviewModal').classList.add('active');
  document.body.style.overflow = 'hidden';
}

function closeReviewModal() {
  document.getElementById('reviewModal').classList.remove('active');
  document.body.style.overflow = '';
}

function setRating(val) {
  selectedRating = val;
  document.querySelectorAll('.star-btn').forEach((btn, i) => {
    btn.classList.toggle('active', i < val);
  });
}

async function handleReviewSubmit(e) {
  const btn = e.target;
  const name = document.getElementById('reviewName').value.trim();
  const product = document.getElementById('reviewProduct').value;
  const text = document.getElementById('reviewText').value.trim();

  if (!name || !product || !text || selectedRating === 0) {
    btn.textContent = 'Please fill in all required fields';
    btn.style.background = '#e57373';
    setTimeout(() => { btn.textContent = 'Submit my review ✨'; btn.style.background = ''; }, 2000);
    return;
  }

  btn.textContent = 'Submitting...';
  btn.disabled = true;

  try {
    const res = await fetch('/api/review', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        name,
        city: document.getElementById('reviewCity').value.trim(),
        product,
        rating: selectedRating,
        text
      })
    });
    if (!res.ok) throw new Error();
  } catch { /* graceful fallback */ }

  btn.textContent = '✅ Thank you! We will review your submission shortly.';
  btn.style.background = 'linear-gradient(135deg,#34d399,#10b981)';
  setTimeout(() => {
    closeReviewModal();
    btn.textContent = 'Submit my review ✨';
    btn.style.background = '';
    btn.disabled = false;
    selectedRating = 0;
    setRating(0);
  }, 2400);
}

