// ── SCROLL REVEAL ──
const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      entry.target.classList.add('visible');
      observer.unobserve(entry.target);
    }
  });
}, { threshold: 0.08 });
document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

// ── SMOOTH SCROLL ──
function scrollToSection(id) {
  const el = document.getElementById(id);
  if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
}

// ── EVENT GALLERY SLIDERS ──
function initEventSliders() {
  document.querySelectorAll('.event-img[data-slider]').forEach(container => {
    const slider = container.querySelector('.event-img-slider');
    const slides = container.querySelectorAll('.event-img-slide');
    const dotsEl = container.querySelector('.event-img-dots');
    if (!slider || slides.length === 0) return;

    let current = 0;

    if (slides.length > 1) {
      slides.forEach((_, i) => {
        const dot = document.createElement('button');
        dot.className = 'event-img-dot' + (i === 0 ? ' active' : '');
        dot.onclick = (e) => { e.stopPropagation(); goTo(i); };
        dotsEl.appendChild(dot);
      });
    }

    function goTo(n) {
      current = (n + slides.length) % slides.length;
      slider.style.transform = `translateX(-${current * 100}%)`;
      container.querySelectorAll('.event-img-dot').forEach((d, i) => {
        d.classList.toggle('active', i === current);
      });
    }

    container._slideEvent = (dir) => goTo(current + dir);

    if (slides.length <= 1) {
      container.querySelectorAll('.event-img-nav').forEach(b => b.style.display = 'none');
      if (dotsEl) dotsEl.style.display = 'none';
    }
  });
}

function slideEvent(e, dir) {
  e.stopPropagation();
  const container = e.target.closest('.event-img[data-slider]');
  if (container && container._slideEvent) container._slideEvent(dir);
}

document.addEventListener('DOMContentLoaded', initEventSliders);
initEventSliders();

// ── DESKTOP NAV ACTIVE ON SCROLL ──
const sections = ['kits','workshops','events','b2b'];
const navLinks = document.querySelectorAll('.nav-links a');

window.addEventListener('scroll', () => {
  let current = '';
  sections.forEach(id => {
    const el = document.getElementById(id);
    if (el && window.scrollY >= el.offsetTop - 120) current = id;
  });
  navLinks.forEach(a => {
    a.classList.remove('active');
    if (a.getAttribute('href') === `#${current}`) a.classList.add('active');
  });
  if (window.scrollY < 200) navLinks[0].classList.add('active');
});
</script>
